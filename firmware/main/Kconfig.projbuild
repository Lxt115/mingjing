menu "Aidoll Device Configuration"

# WiFi 凭据现在通过 NVS + 网页配网管理，不再需要编译期配置
# 设备首次启动会自动进入 AP 配网模式 (SSID: Aidoll-Config)

config DEVICE_ID
    string "Device ID (UUID)"
    help
        Unique identifier for this device. Used for the WebSocket
        device management channel (/ws/device/{id}).

config DEVICE_AGENT_ID
    string "Agent ID"
    help
        The UUID of the AI agent to connect to.

config DEVICE_SERVER_HOST
    string "Server Host"
    help
        IP address or hostname of the backend server.

config DEVICE_SERVER_PORT
    string "Server Port"
    default "8000"
    help
        Port number of the backend server (WebSocket).

endmenu

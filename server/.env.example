# 数据库
# 开发模式（SQLite）
DATABASE_URL=sqlite+aiosqlite:///./mingjing_dev.db
# 生产模式（PostgreSQL）
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mingjing

# ---- 阿里百炼 API Key（STT 使用百炼 Fun-ASR）----
# 申请地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-key

# ---- 火山引擎 API Key（TTS 使用豆包语音合成 2.0）----
# 申请地址: https://console.volcengine.com/speech/
VOLCANO_API_KEY=your-key

# ---- DeepSeek LLM ----
# 申请地址: https://platform.deepseek.com/
LLM_PROVIDER=deepseek
OPENAI_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_MODEL=deepseek-chat

# ---- 服务端 ----
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ---- 联网搜索（秘塔 Metaso / Tavily）----
# SEARCH_PROVIDER=metaso
# SEARCH_API_KEY=你的秘塔API Key
# SEARCH_MAX_RESULTS=3

# ---- 天气查询（和风天气）----
# 申请地址: https://dev.qweather.com/
# WEATHER_API_KEY=你的和风天气API Key
# WEATHER_DEFAULT_LOCATION=北京
